PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="mysql://root:password@localhost:3306/sphinx_db"

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# CORS is allow-all (*) in code — no env needed

FRONTEND_URL=http://localhost:3000

